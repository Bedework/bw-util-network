<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
  <package name="bedework-default" abstract="yes"
           extends="struts-default">
    <interceptors>
      <interceptor-stack name="bedeworkStack">
        <interceptor-ref name="defaultStack">
          <param name="csp.disabled">true</param> </interceptor-ref>
      </interceptor-stack>
    </interceptors>

    <default-interceptor-ref name="bedeworkStack"/>
  </package>
</struts>
